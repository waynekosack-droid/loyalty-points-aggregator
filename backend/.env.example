# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/loyalty_db

# JWT Configuration
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Redis Configuration (optional)
REDIS_URL=redis://localhost:6379/0

# API Configuration
API_V1_STR=/api/v1
PROJECT_NAME=Loyalty Points Aggregator
DEBUG=True

# CORS Configuration
ALLOWED_ORIGINS=["http://localhost:8100","http://localhost:3000"]

# Store API Keys (add as needed)
STARBUCKS_API_KEY=your_starbucks_key
TARGET_API_KEY=your_target_key
MCDONALDS_API_KEY=your_mcdonalds_key
CANADIAN_TIRE_API_KEY=your_canadian_tire_key
PC_POINTS_API_KEY=your_pc_points_key

# Encryption Key
ENCRYPTION_KEY=your-encryption-key-for-sensitive-data
